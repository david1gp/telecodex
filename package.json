{
  "name": "telecodex",
  "version": "0.1.0",
  "description": "Telegram bridge for the OpenAI Codex CLI SDK",
  "license": "MIT",
  "author": "Benedict Evert",
  "repository": {
    "type": "git",
    "url": "https://github.com/benedict2310/telecodex"
  },
  "keywords": [
    "telegram",
    "codex",
    "openai",
    "bot",
    "cli",
    "bridge"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts --hot",
    "build": "tsc",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "format": "biome format --write src test package.json tsconfig.json biome.json"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@openai/codex-sdk": "^0.128.0",
    "grammy": "^1.42.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0",
    "parakeet-coreml": "^2.2.0"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120,
    "trailingComma": "all"
  }
